# DEMO
ENV=development
DEBUG=true
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
DEMO_MODE=true

# ARC
ARC_RPC_URL=http://127.0.0.1:8545
ARC_CHAIN_ID=31337
ARC_USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000
ARC_SENDER_PRIVATE_KEY=
ARCOS_RESEARCH_PRIVATE_KEY=
ARCOS_RESEARCH_WALLET=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ARCOS_COMPUTE_PRIVATE_KEY=
ARCOS_COMPUTE_WALLET=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
ARCOS_COMPUTE_AGENT_KEYS=

# CIRCLE
CIRCLE_API_KEY=
CIRCLE_WALLET_API_URL=https://api.circle.com/v1/w3s/developer/wallets
CIRCLE_WALLET_SET_ID=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_ARC_BLOCKCHAIN=EVM-ARC
CIRCLE_GATEWAY_API_URL=
CIRCLE_GATEWAY_API_KEY=
CIRCLE_NANOPAYMENTS_ENABLED=false

# PAYMENTS
SETTLEMENT_MODE=simulated
ARC_SETTLEMENT_RETRIES=3
ARC_MICROPAYMENT_CAP=10000
ARCOS_ESCROW_ENABLED=true
ARCOS_STREAMING_PAYMENTS_ENABLED=true
ARCOS_SEED_BALANCE=250000000

# INTELLIGENCE
USE_ML_MODEL=false
SCOUT_MODE=lightweight

# ECONOMY
ARCOS_MIN_PRICE_MICRO_USDC=500
ARCOS_MAX_PRICE_MICRO_USDC=10000
ARCOS_MAX_TRANSACTIONS=10000
ARCOS_MAX_EVENTS=5000
ARCOS_EVENT_SUBSCRIBER_QUEUE_SIZE=200
ARCOS_DEMAND_THRESHOLD=1.1
ARCOS_MAX_COMPUTE_AGENTS=10
ARCOS_MAX_TX_PER_SECOND=100
ARCOS_MAX_PERSISTENCE_BACKLOG=3000
ARCOS_ENABLE_BACKPRESSURE=true

# DATABASE
DB_MODE=memory
USE_SUPABASE=false
ARCOS_SQLITE_PATH=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_TABLE_TRANSACTIONS=transactions
ARCOS_PERSISTENCE_QUEUE_SIZE=2000
SUPABASE_WRITE_ENABLED=false
SUPABASE_COMPACT_MODE=true
SUPABASE_DROP_EXPLANATION=true
SUPABASE_WRITE_SAMPLING_RATE=1.0
SUPABASE_MAX_WRITES_PER_SEC=20
SUPABASE_MAX_ROW_SIZE_BYTES=2000
SUPABASE_MAX_BATCH_BYTES=64000
SUPABASE_BATCH_SIZE=50
SUPABASE_FLUSH_INTERVAL_MS=500
SUPABASE_MAX_QUEUE_SIZE=5000
SUPABASE_MAX_RETRIES=4
SUPABASE_RETRY_BASE_MS=100
SUPABASE_REQUEST_TIMEOUT_SEC=5.0

# LOGGING
LOG_LEVEL=INFO
ENABLE_DETAILED_LOGS=false
